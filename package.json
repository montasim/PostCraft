{
  "name": "postcraft",
  "version": "0.0.1",
  "description": "An AI-native social media manager that uses Gemini to generate, score, and schedule high-converting posts while enforcing strict brand guardrails.",
  "keywords": [
    "ai-social-manager",
    "social-media-automation",
    "post-generator",
    "gemini-ai",
    "nextjs",
    "linkedin-automation",
    "twitter-bot",
    "facebook-posting",
    "content-creation",
    "brand-guardrails"
  ],
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack & npx inngest-cli@latest dev -u http://localhost:3000/api/inngest",
    "dev:next": "next dev --turbopack",
    "dev:inngest": "npx inngest-cli@latest dev -u http://localhost:3000/api/inngest",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "seed": "npx tsx scripts/seed-guardrails.ts && npx tsx scripts/seed-persona.ts",
    "seed:guardrails": "npx tsx scripts/seed-guardrails.ts",
    "seed:persona": "npx tsx scripts/seed-persona.ts",
    "test:ai-limits": "npx tsx scripts/test-ai-limits.ts",
    "test:platforms": "npx tsx scripts/test-platforms.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@openrouter/sdk": "^0.12.79",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-select": "^2.1.1",
    "@reduxjs/toolkit": "^2.12.0",
    "@tabler/icons-react": "^3.44.0",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.6.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "inngest": "^4.5.0",
    "mongodb": "^7.2.0",
    "mongoose": "^9.6.2",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "openai": "^6.39.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.4",
    "react-redux": "^9.3.0",
    "resend": "^6.12.3",
    "shadcn": "^4.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  }
}
