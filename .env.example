# Database
MONGODB_URI=mongodb://localhost:27017/linkediq

# AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Queue (Inngest)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# App
NODE_ENV=development

# Auth (Better Auth)
BETTER_AUTH_SECRET=your-secret-min-32-chars
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@linkedIQ.dev

# Logging
LOG_LEVEL=info
