# Database
MONGODB_URI=mongodb://localhost:27017/linkediq

# AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ZhipuAI (optional fallback)
ZAI_API_KEY=
ZAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZAI_MODEL=glm-4.5-air

# Groq (optional)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter (optional)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v3:free
OPENROUTER_SITE_URL=https://linkediq.onrender.com
OPENROUTER_SITE_NAME=linkedIQ

# Queue (Inngest)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# App
NODE_ENV=development
APP_URL=http://localhost:3000

# Auth (Better Auth)
BETTER_AUTH_SECRET=your-secret-min-32-chars
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@linkedIQ.dev

# Logging
LOG_LEVEL=info
