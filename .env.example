# Database
MONGODB_URI=mongodb://localhost:27017/linkediq

# ── AI Providers ────────────────────────────────────────────
# Multi-key support: add _1, _2, _3 suffixes for multiple accounts.
# Numbered variants take priority over bare name if both present.
# Up to 10 keys per provider.

# Gemini (required)
GEMINI_API_KEY=
# OR multiple accounts:
# GEMINI_API_KEY_1=
# GEMINI_API_KEY_2=
GEMINI_MODEL=gemini-2.5-flash

# Groq (optional)
GROQ_API_KEY=
# GROQ_API_KEY_1=
# GROQ_API_KEY_2=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter (optional)
OPENROUTER_API_KEY=
# OPENROUTER_API_KEY_1=
# OPENROUTER_API_KEY_2=
OPENROUTER_MODEL=deepseek/deepseek-v3:free
OPENROUTER_SITE_URL=https://linkediq.onrender.com
OPENROUTER_SITE_NAME=linkedIQ

# ZhipuAI (optional fallback)
ZAI_API_KEY=
# ZAI_API_KEY_1=
# ZAI_API_KEY_2=
ZAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZAI_MODEL=glm-4.5-air

# ── Queue (Inngest) ────────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── App ────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000

# ── Auth (Better Auth) ─────────────────────────────────────
BETTER_AUTH_SECRET=your-secret-min-32-chars
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email (Resend) ─────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@linkedIQ.dev

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=info
